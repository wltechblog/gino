# Picobot Docker Configuration
# Copy this to .env and fill in your values.
# All variables are optional unless marked REQUIRED.

# ── LLM Provider ──────────────────────────────────────

# REQUIRED: API key for your LLM provider
OPENAI_API_KEY=

# API base URL (change for non-OpenRouter providers)
# OpenAI:      https://api.openai.com/v1
# OpenRouter:  https://openrouter.ai/api/v1
# Ollama:      http://localhost:11434/v1
# Groq:        https://api.groq.com/openai/v1
OPENAI_API_BASE=https://openrouter.ai/api/v1

# Model identifier (provider-specific)
PICOBOT_MODEL=google/gemini-2.5-flash

# Max response tokens per message
PICOBOT_MAX_TOKENS=8192

# Max tool call iterations per message
PICOBOT_MAX_TOOL_ITERATIONS=100

# Show "thinking..." indicator during tool calls
PICOBOT_ENABLE_TOOL_ACTIVITY_INDICATOR=true

# ── Telegram ──────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to chat
TELEGRAM_ALLOW_FROM=

# ── Discord ───────────────────────────────────────────

# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=

# Comma-separated Discord user IDs allowed to chat
DISCORD_ALLOW_FROM=

# ── Slack ─────────────────────────────────────────────

# App-level token (xapp-...)
SLACK_APP_TOKEN=

# Bot token (xoxb-...)
SLACK_BOT_TOKEN=

# Comma-separated Slack user IDs allowed to chat
SLACK_ALLOW_USERS=

# Comma-separated Slack channel IDs allowed to chat
SLACK_ALLOW_CHANNELS=

# ── Knowledge Brain ───────────────────────────────────
# The brain provides hybrid search (FTS5 + vector) and a
# knowledge graph over your workspace memory files.
# Requires Ollama (bundled in Docker image) or a remote API.

# Enable the knowledge brain
PICOBOT_BRAIN_ENABLED=false

# Ollama embedding model (auto-pulled on first start)
PICOBOT_BRAIN_EMBEDDING_MODEL=nomic-embed-text

# Ollama server URL (default works inside Docker with bundled Ollama)
# For native Ollama on the host: http://host.docker.internal:11434
PICOBOT_BRAIN_OLLAMA_URL=http://localhost:11434

# ── Remote Embedding API (alternative to Ollama) ──────
# If set, used as fallback when Ollama is unavailable.
# Works with any OpenAI-compatible embedding endpoint.

PICOBOT_BRAIN_REMOTE_API_BASE=
PICOBOT_BRAIN_REMOTE_API_KEY=
PICOBOT_BRAIN_REMOTE_MODEL=
